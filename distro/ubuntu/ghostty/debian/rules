#!/usr/bin/make -f

export HOME = $(CURDIR)
DEB_VERSION := $(shell dpkg-parsechangelog -S Version)
UPSTREAM_VERSION := $(shell echo $(DEB_VERSION) | sed 's/ppa[0-9]*$$//')
STAGE_DIR := $(CURDIR)/debian/tmp

%:
	dh $@

DEB_HOST_ARCH_CPU ?= $(shell dpkg-architecture -qDEB_HOST_ARCH_CPU)

# Select Zig binary based on architecture
ifeq ($(DEB_HOST_ARCH_CPU),amd64)
	ZIG_LOCAL_BIN = ./zig/x86_64/zig
else ifeq ($(DEB_HOST_ARCH_CPU),arm64)
	ZIG_LOCAL_BIN = ./zig/aarch64/zig
else
	ZIG_LOCAL_BIN = ./zig/$(DEB_HOST_ARCH_CPU)/zig
endif

GHOSTTY_BUILD_FLAGS = \
	--system $(CURDIR)/zig-deps/p \
	--prefix /usr \
	-Dversion-string=$(UPSTREAM_VERSION) \
	-Doptimize=ReleaseFast \
	-Dcpu=baseline \
	-Demit-docs=false \
	-Dpie=true \
	-- -fno-lld -fuse-ld=bfd

define select_zig_bin
ZIG_BIN=""; \
if [ -x "$(ZIG_LOCAL_BIN)" ]; then \
	ZIG_BIN="$(ZIG_LOCAL_BIN)"; \
elif [ -x /usr/bin/zig-0.15 ]; then \
	ZIG_BIN="/usr/bin/zig-0.15"; \
elif [ -x /usr/bin/zig ] && /usr/bin/zig version 2>/dev/null | grep -Eq '^0\.(1[5-9]|[2-9][0-9])'; then \
	ZIG_BIN="/usr/bin/zig"; \
else \
	echo "ERROR: No compatible zig binary found ($(ZIG_LOCAL_BIN), /usr/bin/zig-0.15, or /usr/bin/zig >= 0.15)"; \
	exit 1; \
fi
endef

define normalize_staged_tree
if [ ! -d "$(STAGE_DIR)/usr" ]; then \
	echo "ERROR: staged install tree missing at $(STAGE_DIR)/usr"; \
	exit 1; \
fi; \
if [ -d "$(STAGE_DIR)/usr/share/ghostty/themes/ghostty" ]; then \
	mv "$(STAGE_DIR)/usr/share/ghostty/themes/ghostty/"* "$(STAGE_DIR)/usr/share/ghostty/themes/"; \
	rmdir "$(STAGE_DIR)/usr/share/ghostty/themes/ghostty"; \
fi; \
rm -f "$(STAGE_DIR)/usr/share/terminfo/g/ghostty"; \
if [ -f "$(STAGE_DIR)/usr/lib64/libghostty-vt.so" ] || [ -f "$(STAGE_DIR)/usr/lib64/libghostty-vt.so.0" ] || [ -f "$(STAGE_DIR)/usr/lib64/libghostty-vt.so.0.1.0" ]; then \
	mkdir -p "$(STAGE_DIR)/usr/lib"; \
	mv -f "$(STAGE_DIR)/usr/lib64/libghostty-vt.so"* "$(STAGE_DIR)/usr/lib/"; \
fi; \
mkdir -p "$(STAGE_DIR)/usr/share/pkgconfig"; \
PKGCONFIG_DEST="$(STAGE_DIR)/usr/share/pkgconfig/libghostty-vt.pc"; \
for candidate in \
	"$(STAGE_DIR)/usr/lib/pkgconfig/libghostty-vt.pc" \
	"$(STAGE_DIR)/usr/share/pkgconfig/libghostty-vt.pc" \
	"$(STAGE_DIR)/usr/lib64/pkgconfig/libghostty-vt.pc"; \
do \
	if [ -f "$$candidate" ]; then \
		if [ "$$candidate" != "$$PKGCONFIG_DEST" ]; then \
			mv -f "$$candidate" "$$PKGCONFIG_DEST"; \
		fi; \
		break; \
	fi; \
done; \
SYSTEMD_SERVICE_DEST="$(STAGE_DIR)/usr/lib/systemd/user/app-com.mitchellh.ghostty.service"; \
mkdir -p "$(STAGE_DIR)/usr/lib/systemd/user"; \
if [ ! -f "$$SYSTEMD_SERVICE_DEST" ]; then \
	for candidate in \
		"$(STAGE_DIR)/usr/lib/systemd/user/app-com.mitchellh.ghostty.service" \
		"$(STAGE_DIR)/usr/lib/systemd/user/com.mitchellh.ghostty.service" \
		"$(STAGE_DIR)/usr/share/systemd/user/app-com.mitchellh.ghostty.service" \
		"$(STAGE_DIR)/usr/share/systemd/user/com.mitchellh.ghostty.service"; \
	do \
		if [ -f "$$candidate" ]; then \
			cp -a "$$candidate" "$$SYSTEMD_SERVICE_DEST"; \
			break; \
		fi; \
	done; \
fi; \
if [ -f "$(STAGE_DIR)/usr/share/kio/servicemenus/com.mitchellh.ghostty.desktop" ]; then \
	chmod -x "$(STAGE_DIR)/usr/share/kio/servicemenus/com.mitchellh.ghostty.desktop"; \
fi; \
if [ ! -f "$(STAGE_DIR)/usr/lib/libghostty-vt.so" ]; then \
	echo "ERROR: Ghostty VT library was not installed to $(STAGE_DIR)/usr/lib"; \
	exit 1; \
fi; \
if [ ! -f "$(STAGE_DIR)/usr/include/ghostty/vt.h" ]; then \
	echo "ERROR: Ghostty VT headers were not installed to $(STAGE_DIR)/usr/include/ghostty"; \
	exit 1; \
fi; \
if [ ! -f "$$PKGCONFIG_DEST" ]; then \
	echo "ERROR: libghostty-vt.pc not found in staged install tree"; \
	exit 1; \
fi; \
if [ ! -f "$$SYSTEMD_SERVICE_DEST" ]; then \
	echo "ERROR: Ghostty systemd user service file not found in expected paths"; \
	exit 1; \
fi
endef

override_dh_auto_configure:
	# Rewrite theme URL to local tarball and update hash (themes are vendored in source package)
	test -f ghostty-themes.tgz || (echo "ERROR: ghostty-themes.tgz not found!" && exit 1)
	# Update URL to file://
	sed -i "s#https://deps.files.ghostty.org/ghostty-themes-release-[^\"]*\.tgz#file://$(CURDIR)/ghostty-themes.tgz#g" build.zig.zon build.zig.zon.json 2>/dev/null || true
	sed -i "s#https://github.com/mbadolato[^\"]*ghostty-themes.tgz#file://$(CURDIR)/ghostty-themes.tgz#g" build.zig.zon build.zig.zon.json 2>/dev/null || true
	# Update hash to match the fixed themes tarball (required for file:// URLs)
	sed -i '/\.iterm2_themes/,/}/ s|\.hash = "[^"]*"|.hash = "N-V-__8AABVbAwBwDRyZONfx553tvMW8_A2OKUoLzPUSRiLF"|' build.zig.zon 2>/dev/null || true
	sed -i '/"iterm2_themes"/,/\}/ s|"hash": "[^"]*"|"hash": "N-V-__8AABVbAwBwDRyZONfx553tvMW8_A2OKUoLzPUSRiLF"|' build.zig.zon.json 2>/dev/null || true
	# HarfBuzz compatibility: older header sets can lack HB_BUFFER_CLUSTER_LEVEL_GRAPHEMES
	HARFBUZZ_CLUSTER_LEVEL_GRAPHEMES="c.HB_BUFFER_CLUSTER_LEVEL_GRAPHEMES"; \
	if [ ! -d /usr/include/harfbuzz ] || ! grep -R -q "HB_BUFFER_CLUSTER_LEVEL_GRAPHEMES" /usr/include/harfbuzz 2>/dev/null; then \
		if grep -R -q "HB_BUFFER_CLUSTER_LEVEL_CHARACTERS" /usr/include/harfbuzz 2>/dev/null; then \
			HARFBUZZ_CLUSTER_LEVEL_GRAPHEMES="c.HB_BUFFER_CLUSTER_LEVEL_CHARACTERS + 3"; \
		elif grep -R -q "HB_BUFFER_CLUSTER_LEVEL_MONOTONE_GRAPHEMES" /usr/include/harfbuzz 2>/dev/null; then \
			HARFBUZZ_CLUSTER_LEVEL_GRAPHEMES="c.HB_BUFFER_CLUSTER_LEVEL_MONOTONE_GRAPHEMES + 3"; \
		else \
			HARFBUZZ_CLUSTER_LEVEL_GRAPHEMES="c.HB_BUFFER_CLUSTER_LEVEL_MONOTONE_CHARACTERS + 3"; \
		fi; \
	fi; \
	find . -type f -path "*/pkg/harfbuzz/buffer.zig" -exec \
		sed -i "s/enum(u2)/enum(u8)/" {} + || true; \
	find . -type f -path "*/pkg/harfbuzz/buffer.zig" -exec \
		sed -i "s/graphemes = c.HB_BUFFER_CLUSTER_LEVEL_GRAPHEMES/graphemes = $${HARFBUZZ_CLUSTER_LEVEL_GRAPHEMES}/" {} + || true
	# Rewrite wayland dependency URLs to local files (vendored in source package when present)
	if [ -f wayland.tar.gz ]; then \
		sed -i "s#https://deps.files.ghostty.org/wayland-9cb3d7aa9dc995ffafdbdef7ab86a949d0fb0e7d.tar.gz#file://$(CURDIR)/wayland.tar.gz#g" build.zig.zon 2>/dev/null || true; \
	fi
	if [ -f wayland-protocols.tar.gz ]; then \
		sed -i "s#https://deps.files.ghostty.org/wayland-protocols-258d8f88f2c8c25a830c6316f87d23ce1a0f12d9.tar.gz#file://$(CURDIR)/wayland-protocols.tar.gz#g" build.zig.zon 2>/dev/null || true; \
	fi
	if [ -f plasma_wayland_protocols.tar.gz ]; then \
		sed -i "s#https://deps.files.ghostty.org/plasma_wayland_protocols-12207e0851c12acdeee0991e893e0132fc87bb763969a585dc16ecca33e88334c566.tar.gz#file://$(CURDIR)/plasma_wayland_protocols.tar.gz#g" build.zig.zon 2>/dev/null || true; \
	fi
	# Use system linker instead of LLD (avoids libdcimgui.a/libfreetype.so link failure)
	sed -i '/\.use_llvm = true,/a\ .use_lld = false,' src/build/GhosttyExe.zig
	dh_auto_configure

override_dh_auto_build:
	@echo "Skipping explicit build step; zig build install handles staged compilation during install"

override_dh_auto_install:
	@set -e; \
	rm -rf "$(STAGE_DIR)"; \
	$(select_zig_bin); \
	ZIG_GLOBAL_CACHE_DIR=$(CURDIR)/zig-deps \
	DESTDIR="$(STAGE_DIR)" "$$ZIG_BIN" build install $(GHOSTTY_BUILD_FLAGS); \
	$(normalize_staged_tree)

override_dh_auto_clean:
	rm -rf zig-cache zig-out .zig-cache
	dh_auto_clean
